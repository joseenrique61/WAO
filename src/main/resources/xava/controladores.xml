    -->

    <controlador nombre="Animal">
        <hereda-de controlador="Typical"/>
        <accion nombre="establecerListoParaAdopcion" modo="detail"
                clase="com.wao.WAO.acciones.EstablecerListoParaAdopcion"/>
    </controlador>

    <controlador nombre="Defuncion">
        <hereda-de controlador="Typical"/>
        <accion nombre="save" modo="detail" por-defecto="si-posible" clase="com.wao.WAO.acciones.RegistrarDefuncion"
                confirmar="true"/>
    </controlador>

    <controlador nombre="ContratoAdopcion">
        <hereda-de controlador="Typical"/>
        <accion nombre="save" modo="detail" por-defecto="si-posible"
                clase="com.wao.WAO.acciones.RegistrarContratoAdopcion"/>
    </controlador>

    <controlador nombre="CuadroMando">
